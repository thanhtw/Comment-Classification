# Copy to .env and adjust values for your machine

# Project paths
PROJECT_ROOT=.
DATA_FILE=./data/Dataset.csv
RESULTS_ROOT=./results

# Python environment
PYTHONUTF8=1
ML_USE_GPU=0

# Groq API Configuration (required for LLM pipeline)
# Leave empty or comment out if you don't have Groq access
Groq_API_KEY=

# LLM Model Configuration
# Comma-separated list of Groq model IDs to use
LLM_MODEL_NAMES=openai/gpt-oss-20b,llama-3.3-70b-versatile

# Max samples to evaluate with LLM (default 200)
LLM_MAX_SAMPLES=200
